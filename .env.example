# MAPA — environment variables template
# Copy to .env.local (gitignored) and fill values. Never commit .env.local.

# ─── Mantle RPC ─────────────────────────────────────────────
# Mantle Sepolia testnet (chain 5003) — primary dev target
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
# Mantle Mainnet (chain 5000) — final deploy target
MANTLE_MAINNET_RPC_URL=https://rpc.mantle.xyz

# ─── Mantlescan (block explorer + verification) ─────────────
# Get key at https://mantlescan.xyz/myapikey (works for both mainnet + sepolia)
MANTLESCAN_API_KEY=

# ─── Deployer wallet ────────────────────────────────────────
# Private key of EOA that deploys contracts. Funded with Sepolia MNT via faucet.
# DO NOT commit. DO NOT use a wallet that holds real funds.
DEPLOYER_PRIVATE_KEY=

# ─── Oracle signer ──────────────────────────────────────────
# Separate EOA used by off-chain pipeline to sign PnL snapshots.
# Authorized address is set in BetMarket constructor on deploy.
ORACLE_PRIVATE_KEY=

# ─── MAPA Judge (ERC-8004 mirror) ───────────────────────────
# Separate EOA used to call ERC-8004 Reputation.giveFeedback() for our agents.
# MUST NOT be the agent owner (EIP-8004 verbatim restriction).
# Used only by ERC8004ReputationAdapter.mirrorElo(). Bonus narrative path.
JUDGE_PRIVATE_KEY=

# ─── ERC-8004 Reputation Registry (verified 2026-05-10) ─────
# Mainnet: 0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
# Sepolia: 0x8004B663056A597Dffe9eCcC1965A193B7388713
ERC_8004_REPUTATION_SEPOLIA=0x8004B663056A597Dffe9eCcC1965A193B7388713
ERC_8004_REPUTATION_MAINNET=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
ERC_8004_IDENTITY_SEPOLIA=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC_8004_IDENTITY_MAINNET=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432

# ─── Allora Network ─────────────────────────────────────────
# Allora topics on Mantle: BTC/USD topic 1 (10min) — primary
# MNT/USDC topic does NOT exist (verified 2026-05-10 audit). Use BTC/USD.
ALLORA_TOPIC_ID=1
ALLORA_FEED_ADDRESS=

# ─── USDC token ─────────────────────────────────────────────
# Mantle Mainnet USDC: 0x09Bc4E0D864854c6aFB6eB9A9cdF58aC190D0dF9
# Mantle Sepolia: no canonical USDC — MockUSDC deployed in Phase A1 (2026-05-11)
USDC_ADDRESS_MAINNET=0x09Bc4E0D864854c6aFB6eB9A9cdF58aC190D0dF9
USDC_ADDRESS_SEPOLIA=0xB4B6b0Df73FAd5B04CcE4436FB79F8bddb9e0d3D

# ─── Frontend (NEXT_PUBLIC_*) ───────────────────────────────
# Sepolia values from Phase A1 deploy (2026-05-11). Mainnet TBD in Phase E.
NEXT_PUBLIC_CHAIN_ID=5003
NEXT_PUBLIC_BET_MARKET_ADDRESS=0x341bA158c2367a49EE2097842e671Dc3510F654f
NEXT_PUBLIC_ARENA_REGISTRY_ADDRESS=0xBAf698174888228DAac3c245361a9981c27dc692
NEXT_PUBLIC_ODDS_ORACLE_ADDRESS=0xAD76538C09785C9C0dCD67A56E9656274fdCe890
NEXT_PUBLIC_MOCK_REPUTATION_ADDRESS=0x1FfB5FD6B3F84Cdb805AFC6796B0BA64828b24c6
NEXT_PUBLIC_ERC8004_ADAPTER_ADDRESS=0x7636c039224255388F2351a387623842fa784f2f
NEXT_PUBLIC_USDC_ADDRESS=0xB4B6b0Df73FAd5B04CcE4436FB79F8bddb9e0d3D

# WalletConnect / RainbowKit project ID — get at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=
