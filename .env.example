# MAPA — environment variables template
# Copy to .env (gitignored) and fill values. Never commit .env.

# ─── Mantle RPC ─────────────────────────────────────────────
# Mantle Sepolia testnet (chain 5003) — primary dev target
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
# Mantle Mainnet (chain 5000) — final deploy target
MANTLE_MAINNET_RPC_URL=https://rpc.mantle.xyz

# ─── Mantlescan (block explorer + verification) ─────────────
# Get key at https://mantlescan.xyz/myapikey
MANTLESCAN_API_KEY=

# ─── Deployer wallet ────────────────────────────────────────
# Private key of EOA that deploys contracts. Funded with Sepolia MNT via faucet.
# DO NOT commit. DO NOT use a wallet that holds real funds.
DEPLOYER_PRIVATE_KEY=

# ─── Oracle signer ──────────────────────────────────────────
# Separate EOA used by off-chain pipeline to sign PnL snapshots.
# Authorized address is set in BetMarket constructor on deploy.
ORACLE_PRIVATE_KEY=

# ─── ERC-8004 / Reputation registry ─────────────────────────
# Address of ERC-8004 Identity Registry on Mantle.
# If not yet published — leave empty, fallback to MockReputation in Phase A2.
ERC_8004_REGISTRY_ADDRESS=

# ─── Allora Network ─────────────────────────────────────────
# Allora feed contract address on Mantle (TBD — verify in Phase A1)
ALLORA_FEED_ADDRESS=

# ─── USDC token ─────────────────────────────────────────────
# Mantle USDC mainnet: 0x09Bc4E0D864854c6aFB6eB9A9cdF58aC190D0dF9 (verify before mainnet deploy)
# Mantle Sepolia USDC: TBD (deploy MockUSDC in Phase A1 if needed)
USDC_ADDRESS=

# ─── ClawHack / RealClaw subgraph ───────────────────────────
# URL to query agent PnL data. Empty → use synthetic data from data/agents-fallback.json
REALCLAW_SUBGRAPH_URL=

# ─── Frontend (NEXT_PUBLIC_*) ───────────────────────────────
NEXT_PUBLIC_CHAIN_ID=5003
NEXT_PUBLIC_BET_MARKET_ADDRESS=
NEXT_PUBLIC_ARENA_REGISTRY_ADDRESS=
NEXT_PUBLIC_ODDS_ORACLE_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

# WalletConnect / RainbowKit project ID — get at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=
